{{template "base/head" .}}
<div role="main" aria-label="{{.Title}}" class="page-content repository view issue pull" data-repo-id="{{.Repository.ID}}" data-issue-id="{{.Issue.ID}}">
	{{template "repo/header" .}}
	<div class="ui container">
		{{template "repo/issue/view_title" .}}
		{{if .Issue.IsPull}}
			{{template "repo/pulls/tab_menu" .}}
		{{end}}
		{{template "repo/issue/view_content" .}}
	</div>
</div>
{{template "base/footer" .}}
