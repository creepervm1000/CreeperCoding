{{template "base/head" .}}
<div role="main" aria-label="{{.Title}}" class="page-content repository agent">
	{{template "repo/header" .}}
	<div class="ui container">
		<div class="ui segment">
			<div id="agent-messages" class="tw-mb-4" style="min-height: 300px; max-height: 500px; overflow-y: auto; border: 1px solid #ddd; border-radius: 4px; padding: 1em;">
				<div class="tw-text-center tw-text-gray-500">
					{{svg "octicon-bot" 24}}
					<p>{{ctx.Locale.Tr "repo.agent.welcome"}}</p>
				</div>
			</div>
			<form id="agent-form" class="ui form">
				{{.CSRFTokenHTML}}
				<div class="ui action input tw-flex">
					<input type="text" id="agent-input" placeholder="{{ctx.Locale.Tr "repo.agent.placeholder"}}">
					<button class="ui primary button" type="submit">{{ctx.Locale.Tr "repo.agent.send"}}</button>
				</div>
			</form>
		</div>
	</div>
</div>
<script>
document.getElementById('agent-form').addEventListener('submit', async (e) => {
	e.preventDefault();
	const input = document.getElementById('agent-input');
	const msg = input.value.trim();
	if (!msg) return;

	const container = document.getElementById('agent-messages');
	const userMsg = document.createElement('div');
	userMsg.className = 'tw-mb-2';
	userMsg.innerHTML = '<strong>You:</strong> ' + escapeHtml(msg);
	container.appendChild(userMsg);

	input.value = '';
	input.disabled = true;

	const loading = document.createElement('div');
	loading.className = 'tw-mb-2 tw-text-gray-500';
	loading.textContent = 'ccopilot is thinking...';
	container.appendChild(loading);
	container.scrollTop = container.scrollHeight;

	try {
		const resp = await fetch('{{.RepoLink}}/agent/chat', {
			method: 'POST',
			headers: {
				'Content-Type': 'application/json',
				'X-Csrf-Token': document.querySelector('input[name=_csrf]').value,
			},
			body: JSON.stringify({message: msg}),
		});
		const data = await resp.json();
		loading.remove();
		const botMsg = document.createElement('div');
		botMsg.className = 'tw-mb-2';
		botMsg.innerHTML = '<strong>ccopilot:</strong> ' + escapeHtml(data.reply);
		container.appendChild(botMsg);
	} catch (err) {
		loading.remove();
		const errMsg = document.createElement('div');
		errMsg.className = 'tw-mb-2 tw-text-red';
		errMsg.textContent = 'Error: ' + err.message;
		container.appendChild(errMsg);
	} finally {
		input.disabled = false;
		input.focus();
	}
	container.scrollTop = container.scrollHeight;
});

function escapeHtml(str) {
	const div = document.createElement('div');
	div.textContent = str;
	return div.innerHTML;
}
</script>
{{template "base/footer" .}}